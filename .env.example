# Copy to .env and fill in your keys.
# Configure at least ONE LLM provider — the app auto-detects which to use
# (Anthropic wins when both are set).
ANTHROPIC_API_KEY=sk-ant-...
# free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
TAVILY_API_KEY=tvly-...
# Optional overrides
# LLM_PROVIDER=anthropic        # or "gemini" — force a provider when both keys are set
# MODEL_GEMINI_SMART=gemini-2.5-flash
# MODEL_GEMINI_FAST=gemini-2.5-flash-lite
# DB_PATH=data/constructiq.db
# CHROMA_PATH=data/chroma
# FRONTEND_ORIGIN=http://localhost:8501
